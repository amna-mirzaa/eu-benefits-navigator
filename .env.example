# Groq — free tier, no credit card required: https://console.groq.com/keys
GROQ_API_KEY=

# Pinecone — free Starter tier: https://app.pinecone.io/
PINECONE_API_KEY=
PINECONE_INDEX=eu-benefits
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# Model routing (Groq model ids)
GROQ_FAST_MODEL=llama-3.3-70b-versatile
GROQ_REASONING_MODEL=openai/gpt-oss-120b

# Local embedding model (sentence-transformers, runs on CPU, no API key needed)
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
